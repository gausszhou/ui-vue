{
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "target": "es2016",
    "sourceMap": false,
    "module": "esnext",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "jsx": "preserve",
    "lib": ["esnext", "dom"],
    "rootDir": ".",
    "moduleResolution": "node",
    "declaration": true,
    "declarationDir": "dist/types",
    "skipLibCheck": true,
    "types": ["vite/client"]
  },
  "include": ["**/*.ts", "**/*.d.ts", "**/*.vue"]
}